# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# For Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/expirio

# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/expirio?retryWrites=true&w=majority

# CORS Configuration (optional)
# CORS_ORIGIN=http://localhost:3000

# JWT Configuration (for future authentication implementation)
# JWT_SECRET=your_secret_key_here
# JWT_EXPIRE=7d
